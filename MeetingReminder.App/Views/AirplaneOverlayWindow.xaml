<Window x:Class="MeetingReminder.App.Views.AirplaneOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize">

    <Canvas x:Name="FlightCanvas" ClipToBounds="True">
        <!-- The airplane assembly: banner + plane glyph -->
        <StackPanel x:Name="AirplaneAssembly" Orientation="Horizontal"
                    Canvas.Top="10">
            <!-- Banner with meeting text -->
            <Border CornerRadius="8" Padding="20,10"
                    Background="{DynamicResource AccentBrush}">
                <Border.Effect>
                    <DropShadowEffect Color="#11111b" Opacity="0.4"
                                      BlurRadius="12" ShadowDepth="4"/>
                </Border.Effect>
                <TextBlock x:Name="BannerText"
                           FontSize="22"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI, Comic Sans MS"
                           Foreground="{DynamicResource BaseBrush}"/>
            </Border>

            <!-- Cat mascot image -->
            <Image Source="/Assets/cat.png"
                   Width="80" Height="80"
                   VerticalAlignment="Center"
                   Margin="-8,0,0,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </StackPanel>
    </Canvas>
</Window>
