<Window x:Class="MeetingReminder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MeetingReminder.App.ViewModels"
        xmlns:conv="clr-namespace:MeetingReminder.App.Converters"
        Title="MeetingReminder"
        Height="520" Width="680"
        MinHeight="400" MinWidth="520"
        Background="{DynamicResource BaseBrush}"
        Foreground="{DynamicResource TextBrush}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Ideal"
        mc:Ignorable="d">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InvertedBoolToVisibilityConverter x:Key="InvertBoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title strip -->
        <Border Background="{DynamicResource CrustBrush}" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🐱" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="MeetingReminder" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock Text="Never miss a meeting again"
                           Foreground="{DynamicResource Subtext0Brush}"
                           FontSize="12" Margin="12,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="{DynamicResource BaseBrush}">

            <!-- ============ Upcoming tab ============ -->
            <TabItem Header="Upcoming">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Calendar access bar -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding HasCalendarAccess, Converter={StaticResource InvertBoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Connect a calendar"
                                       Style="{StaticResource HeaderTextBlock}"/>
                            <TextBlock Text="Choose a calendar source to monitor for upcoming meetings."
                                       Style="{StaticResource SubtleTextBlock}" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Windows Calendar"
                                        Command="{Binding RequestCalendarAccessCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,8,0"/>
                                <Button Content="Google Calendar"
                                        Command="{Binding ConnectGoogleCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Google connected indicator -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding HasGoogleAccess, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓ Google Calendar connected"
                                       Foreground="{DynamicResource GreenBrush}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Content="Disconnect" Margin="12,0,0,0"
                                    Command="{Binding DisconnectGoogleCommand}"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Button bar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12"
                                Visibility="{Binding HasCalendarAccess, Converter={StaticResource BoolToVis}}">
                        <Button Content="Refresh" Command="{Binding RefreshUpcomingCommand}" Margin="0,0,8,0"/>
                        <Button Content="Test cat" Command="{Binding TestAirplaneCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>

                    <!-- Upcoming meetings list -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0"
                            Visibility="{Binding HasCalendarAccess, Converter={StaticResource BoolToVis}}">
                        <ListBox ItemsSource="{Binding UpcomingMeetings}"
                                 Background="{DynamicResource MantleBrush}"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="SemiBold" FontSize="13">
                                            <Run Text="{Binding StartTime, Mode=OneWay}"/>
                                            <Run Text="–" Foreground="{DynamicResource Overlay0Brush}"/>
                                            <Run Text="{Binding EndTime, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============ Settings tab ============ -->
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" MaxWidth="520" HorizontalAlignment="Left">

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Alert" Style="{StaticResource HeaderTextBlock}"/>
                                <TextBlock Text="Minutes before meeting" Style="{StaticResource LabelTextBlock}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0"
                                            Minimum="1" Maximum="30"
                                            Value="{Binding Settings.AlertMinutesBefore, UpdateSourceTrigger=PropertyChanged}"
                                            TickFrequency="5" IsSnapToTickEnabled="False"
                                            VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Settings.AlertMinutesBefore, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="12,0,0,0"
                                             HorizontalContentAlignment="Right"/>
                                </Grid>
                                <TextBlock Style="{StaticResource SubtleTextBlock}"
                                           Text="Between 1 and 30 minutes. Default 5."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Cat speed" Style="{StaticResource HeaderTextBlock}"/>
                                <TextBlock Text="How long the cat takes to cross the screen"
                                           Style="{StaticResource LabelTextBlock}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button Content="Slow" Margin="0,0,8,0"
                                            Command="{Binding Settings.SetSpeedCommand}"
                                            CommandParameter="22"/>
                                    <Button Content="Normal" Margin="0,0,8,0"
                                            Style="{StaticResource PrimaryButton}"
                                            Command="{Binding Settings.SetSpeedCommand}"
                                            CommandParameter="14"/>
                                    <Button Content="Fast"
                                            Command="{Binding Settings.SetSpeedCommand}"
                                            CommandParameter="8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Startup" Style="{StaticResource HeaderTextBlock}"/>
                                <CheckBox Content="Start with Windows"
                                          IsChecked="{Binding Settings.StartWithWindows}"/>
                                <CheckBox Content="Start minimised to system tray"
                                          IsChecked="{Binding Settings.StartMinimized}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Google Calendar" Style="{StaticResource HeaderTextBlock}"/>
                                <TextBlock Style="{StaticResource SubtleTextBlock}" Margin="0,0,0,8"
                                           Text="Paste your OAuth2 credentials from Google Cloud Console. Or place a client_secrets.json file next to the app."/>
                                <TextBlock Text="Client ID" Style="{StaticResource LabelTextBlock}"/>
                                <TextBox Text="{Binding Settings.GoogleClientId, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,8"/>
                                <TextBlock Text="Client Secret" Style="{StaticResource LabelTextBlock}"/>
                                <TextBox Text="{Binding Settings.GoogleClientSecret, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,8"/>
                                <Button Content="Connect Google Calendar"
                                        Command="{Binding ConnectGoogleCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Appearance" Style="{StaticResource HeaderTextBlock}"/>
                                <TextBlock Text="Theme" Style="{StaticResource LabelTextBlock}"/>
                                <ComboBox ItemsSource="{Binding Settings.AvailableThemes}"
                                          SelectedItem="{Binding Settings.Theme, UpdateSourceTrigger=PropertyChanged}"
                                          MaxWidth="200" HorizontalAlignment="Left"
                                          Margin="0,0,0,12"/>

                                <TextBlock Text="Accent" Style="{StaticResource LabelTextBlock}"/>
                                <ComboBox ItemsSource="{Binding Settings.AvailableAccents}"
                                          SelectedItem="{Binding Settings.Accent, UpdateSourceTrigger=PropertyChanged}"
                                          MaxWidth="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="About" Style="{StaticResource HeaderTextBlock}"/>
                                <TextBlock Style="{StaticResource SubtleTextBlock}"
                                           Text="MeetingReminder — flies a cat across your screen before meetings."/>
                                <TextBlock Style="{StaticResource SubtleTextBlock}" Margin="0,4,0,0"
                                           Text="Windows port of conniexu444/meeting-reminder."/>
                                <TextBlock Style="{StaticResource SubtleTextBlock}" Margin="0,4,0,0"
                                           Text="Theme: Catppuccin (catppuccin/catppuccin on GitHub)"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ Log tab ============ -->
            <TabItem Header="Log">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Content="Auto-scroll"
                                  IsChecked="{Binding Log.AutoScroll}"/>
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <ListBox x:Name="LogList"
                                 ItemsSource="{Binding Log.Lines}"
                                 Background="{DynamicResource MantleBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderThickness="0"
                                 FontFamily="Consolas, Courier New"
                                 FontSize="12"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{DynamicResource MantleBrush}" Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource Subtext1Brush}"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="1"
                        Style="{StaticResource StatusPill}"
                        Background="{DynamicResource Surface0Brush}"
                        Visibility="{Binding IsFlying, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="🐱 Flying!"
                               Foreground="{DynamicResource MauveBrush}"
                               FontWeight="SemiBold" FontSize="12"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
