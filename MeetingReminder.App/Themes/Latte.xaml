<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <sys:String xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                x:Key="ThemeFlavor">Latte</sys:String>

    <!-- Backgrounds: Latte inverts the depth order — lightest in front. -->
    <SolidColorBrush x:Key="CrustBrush"    Color="#dce0e8"/>
    <SolidColorBrush x:Key="MantleBrush"   Color="#e6e9ef"/>
    <SolidColorBrush x:Key="BaseBrush"     Color="#eff1f5"/>
    <SolidColorBrush x:Key="Surface0Brush" Color="#ccd0da"/>
    <SolidColorBrush x:Key="Surface1Brush" Color="#bcc0cc"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="#acb0be"/>

    <SolidColorBrush x:Key="Overlay0Brush" Color="#9ca0b0"/>
    <SolidColorBrush x:Key="Overlay1Brush" Color="#8c8fa1"/>
    <SolidColorBrush x:Key="Overlay2Brush" Color="#7c7f93"/>

    <SolidColorBrush x:Key="TextBrush"     Color="#4c4f69"/>
    <SolidColorBrush x:Key="Subtext1Brush" Color="#5c5f77"/>
    <SolidColorBrush x:Key="Subtext0Brush" Color="#6c6f85"/>

    <!-- Full Catppuccin Latte accent palette (all 14) -->
    <SolidColorBrush x:Key="RosewaterBrush" Color="#dc8a78"/>
    <SolidColorBrush x:Key="FlamingoBrush"  Color="#dd7878"/>
    <SolidColorBrush x:Key="PinkBrush"      Color="#ea76cb"/>
    <SolidColorBrush x:Key="MauveBrush"     Color="#8839ef"/>
    <SolidColorBrush x:Key="RedBrush"       Color="#d20f39"/>
    <SolidColorBrush x:Key="MaroonBrush"    Color="#e64553"/>
    <SolidColorBrush x:Key="PeachBrush"     Color="#fe640b"/>
    <SolidColorBrush x:Key="YellowBrush"    Color="#df8e1d"/>
    <SolidColorBrush x:Key="GreenBrush"     Color="#40a02b"/>
    <SolidColorBrush x:Key="TealBrush"      Color="#179299"/>
    <SolidColorBrush x:Key="SkyBrush"       Color="#04a5e5"/>
    <SolidColorBrush x:Key="SapphireBrush"  Color="#209fb5"/>
    <SolidColorBrush x:Key="BlueBrush"      Color="#1e66f5"/>
    <SolidColorBrush x:Key="LavenderBrush"  Color="#7287fd"/>

    <SolidColorBrush x:Key="AccentBrush"   Color="#1e66f5"/>   <!-- Latte default: Blue -->
    <SolidColorBrush x:Key="SuccessBrush"  Color="#40a02b"/>
    <SolidColorBrush x:Key="WarningBrush"  Color="#df8e1d"/>
    <SolidColorBrush x:Key="ErrorBrush"    Color="#d20f39"/>
    <SolidColorBrush x:Key="FocusBrush"    Color="#7287fd"/>
    <SolidColorBrush x:Key="CaretBrush"    Color="#dc8a78"/>

    <SolidColorBrush x:Key="SelectionBrush" Color="#7c7f93" Opacity="0.25"/>

</ResourceDictionary>
